// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
 // output   = "../node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Registry {
  id        String   @id @default("main")
  baseUrl  String
  publicKey String
  createdAt DateTime @default(now())
  privateKey String?
  @@map("tbl_registry")
}


model Settings{
  id             String          @default(uuid())
  name           String          @id @unique
  value          Json
  dataType       SettingDataType
  requiredFields String[]
  isReadOnly     Boolean         @default(false)
  isPrivate      Boolean         @default(true)

  @@map("tbl_settings")
}

model Beneficiary{
  id   Int    @id @default(autoincrement()) @db.Integer()
  uuid String @unique @default(uuid()) @db.Uuid()
  walletAddress String 
  requestId    String ?
  disbursementAmount  Int?
  disbursementStatus DisbursementStatus  @default(NOTSTARTED)
  pii                  BeneficiaryPii?        @relation("BeneficiaryToPii")
  group                BeneficiaryGroupMember?  @relation("BeneficiaryGroupMember")

  createdAt    DateTime  @default(now())
  updatedAt    DateTime?   @updatedAt

  @@map("tbl_beneficiary")   
}


model BeneficiaryPii{
  beneficiaryId        Int @unique
  name                 String?
  phone                String @unique
  email                String ?
  extras               Json?  @db.JsonB()
  beneficiary   Beneficiary @relation("BeneficiaryToPii", fields: [beneficiaryId], references: [id])

  @@map("tbl_beneficiary_pii")
}

model BeneficiaryWallet{
  uuid          String @unique @default(uuid())
  walletAddress  String @unique
  keyDetails      String
  createdAt       DateTime @default(now())

  @@map("tbl_beneficiary_wallet")
}


model Vendor{
  uuid       String @unique @default(uuid())
  name       String 
  phoneNumber String 
  email       String ?
  walletAddress String 
  createdAt   DateTime @default(now())
  updatedAt   DateTime?
}

model BeneficiaryGroup {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime?
  members     BeneficiaryGroupMember[]
  @@map("tbl_beneficiary_group")
}

model BeneficiaryGroupMember {
  id                Int    @id @default(autoincrement())
  groupId           Int
  beneficiaryId     Int     @unique()
  group             BeneficiaryGroup @relation(fields: [groupId], references: [id])
  beneficiary       Beneficiary      @relation("BeneficiaryGroupMember", fields: [beneficiaryId], references: [id])
  joinedAt          DateTime @default(now())
  @@unique([groupId, beneficiaryId])
  @@map("tbl_beneficiary_group_member")
}


enum SettingDataType {
  STRING
  NUMBER
  BOOLEAN
  OBJECT
}

enum DisbursementStatus{
  CREATED
  FAILED
  DISBURSED
  NOTSTARTED
  PENDING

}
